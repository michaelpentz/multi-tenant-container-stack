# Monitoring Stack Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env files to version control!

# ============================================
# Grafana Configuration
# ============================================

# Admin username for Grafana web interface
GRAFANA_ADMIN_USER=admin

# Admin password for Grafana
# Generate a strong password (e.g., using: openssl rand -base64 24)
GRAFANA_ADMIN_PASSWORD=change-me-to-secure-password

# Root URL for Grafana (update for production)
# Examples:
#   Local: http://localhost:3000
#   Production: https://grafana.yourdomain.com
GRAFANA_ROOT_URL=http://localhost:3000

# ============================================
# System Configuration
# ============================================

# Timezone for logs and timestamps
TZ=America/New_York

# ============================================
# Security Settings (Optional)
# ============================================

# Disable analytics and reporting
# GF_ANALYTICS_REPORTING_ENABLED=false
# GF_ANALYTICS_CHECK_FOR_UPDATES=false

# Session configuration
# GF_SESSION_COOKIE_SECURE=true
# GF_SESSION_COOKIE_SAMESITE=strict
