# Foundry VTT Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env files to version control!

# ============================================
# FoundryVTT Configuration
# ============================================

# FoundryVTT Version to use
# Check available versions: https://github.com/felddy/foundryvtt-docker/releases
FOUNDRY_VERSION=13.351

# ============================================
# Foundry Account Credentials
# ============================================

# Your Foundry VTT account email
FOUNDRY_USERNAME=your-email@example.com

# Your Foundry VTT account password
# NOTE: Docker secrets or external vault recommended for production
FOUNDRY_PASSWORD=your-secure-password-here

# ============================================
# Admin & Security
# ============================================

# Admin Access Key for GM access to the setup screen
# Generate a strong random string (e.g., using: openssl rand -base64 32)
FOUNDRY_ADMIN_KEY=change-me-to-secure-random-key

# ============================================
# License Keys
# ============================================

# Foundry VTT License Keys (one per campaign instance)
# Get your license from: https://foundryvtt.com/
FOUNDRY_LICENSE_KEY_1=XXXX-XXXX-XXXX-XXXX-XXXX-XXXX
FOUNDRY_LICENSE_KEY_2=XXXX-XXXX-XXXX-XXXX-XXXX-XXXX

# ============================================
# System Configuration
# ============================================

# Timezone for logs and container timestamps
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# ============================================
# Optional Settings (Uncomment to use)
# ============================================

# Enable SSL/TLS (recommended for production)
# FOUNDRY_SSL_CERT=/path/to/cert.pem
# FOUNDRY_SSL_KEY=/path/to/key.pem

# Proxy URL if behind reverse proxy
# FOUNDRY_PROXY_PORT=443
# FOUNDRY_PROXY_SSL=true

# World to auto-launch (skips setup screen)
# FOUNDRY_WORLD=my-world-name
