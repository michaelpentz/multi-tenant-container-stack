# FileBrowser Configuration
# Copy this file to .env and fill in your actual values

# Path to Foundry VTT data directory
# This should point to the directory containing campaign data and shared_assets
# Examples:
#   Local: ./data
#   Absolute: /home/foundry/foundry_docker/data
#   Relative to compose file: ../foundry-vtt/data
FOUNDRY_DATA_PATH=./data

# Timezone for logs and timestamps
TZ=America/New_York
